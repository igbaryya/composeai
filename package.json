{
  "name": "composeai-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Monorepo for composeai — a React composer library for AI chat and assistant interfaces, plus the interactive demo gallery.",
  "workspaces": [
    "package",
    "demo"
  ],
  "scripts": {
    "build": "npm run build -w composeai && tsc -p tsconfig.json --noEmit && vite build",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "dependencies": {
    "@lexical/code": "^0.45.0",
